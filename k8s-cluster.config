                            'active': True,
                            'metric': 'gauge',
                            'query': '100*sum(pgbouncer_pools_server_active_connections) / sum(pgbouncer_pools_server_active_connections + pgbouncer_pools_server_idle_connections + pgbouncer_pools_server_used_connections)',
                            'title': 'PgBouncer Pool Utilization Ratio [%]'
                        },
                        'pgbouncer_pool_utilization': {
                            'type': 'application',
                            'active': True,
                            'metric': 'gauge',
                            'query': '100*sum(pgbouncer_pools_server_active_connections + pgbouncer_pools_server_used_connections) / sum(pgbouncer_pools_server_active_connections + pgbouncer_pools_server_idle_connections + pgbouncer_pools_server_used_connections)',
                            'title': 'PgBouncer Pool Load Pressure [%]'
                        },
                        'pgbouncer_received_bytes_rate': {
                            'type': 'application',
                            'active': True,
                            'metric': 'counter',
                            'query': 'sum(pgbouncer_stats_totals_received_bytes_total)/1024/1024/1024',
                            'title': 'PgBouncer Ingress [Gi]'
                        },
                        'pgbouncer_sent_bytes_rate': {
                            'type': 'application',
                            'active': True,
                            'metric': 'counter',
                            'query': 'sum(pgbouncer_stats_totals_sent_bytes_total)/1024/1024/1024',
                            'title': 'PgBouncer Egress [Gi]'
                        },
                        'pgbouncer_server_assignments_rate': {
                            'type': 'application',
                            'active': True,
                            'metric': 'counter',
                            'query': 'sum(pgbouncer_stats_totals_server_assignments_total)',
                            'title': 'PgBouncer Server Assignments [connections]'
                        },
                    }
                }
            },
        },
    },
