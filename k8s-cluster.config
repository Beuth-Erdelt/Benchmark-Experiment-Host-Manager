{
    'benchmarker': {
        'resultfolder': '/home/myself/benchmarks',
        'jarfolder': './jars/'
    },
    'credentials': {
        'k8s': {
            'appname': 'bexhoma',
            'context': {
                'dummy': {
                    'namespace': 'dummy',
                    'clustername': 'Dummy',
                    'service_sut': '{service}.{namespace}.svc.cluster.local',
                    'port': 9091, # K8s: Local port for connecting via JDBC after port forwarding
                },
            },
            'monitor': {
                'service_monitoring': 'https://prometheus.mycluster.com/api/v1/',
                'service_monitoring_application': 'http://{service}.{namespace}.svc.cluster.local:9090/api/v1/',
                'extend': 20,
                'shift': 0,
                'metrics': {
                    'total_cpu_memory': {
                        'type': 'cluster',
                        'active': True,
                        'metric': 'gauge',
                        'query': '(sum(max(container_memory_working_set_bytes{{pod=~"(.*){configuration}-{experiment}(.*)", pod=~"(.*){configuration}-{experiment}(.*)", container="dbms"}}) by (instance)))/1024/1024',
                        'title': 'Memory Usage [MiB]'
                    },
                    'total_cpu_memory_cached': {
                        'type': 'cluster',
                        'active': True,
                        'metric': 'gauge',
                        'query': '(sum(max(container_memory_usage_bytes{{pod=~"(.*){configuration}-{experiment}(.*)", pod=~"(.*){configuration}-{experiment}(.*)", container="dbms"}}) by (instance)))/1024/1024',
                        'title': 'Memory Usage Cached [MiB]'
                    },
                    'total_cpu_util': {
                        'type': 'cluster',
                        'active': True,
                        'metric': 'gauge',
                        'query': 'sum(irate(container_cpu_usage_seconds_total{{pod=~"(.*){configuration}-{experiment}(.*)", pod=~"(.*){configuration}-{experiment}(.*)", container="dbms"}}[5m]))',
                        'title': 'CPU Utilization'
                    },
                    'total_cpu_throttled': {
                        'type': 'cluster',
                        'active': True,
                        'metric': 'gauge',
                        'query': 'sum(irate(container_cpu_cfs_throttled_seconds_total{{pod=~"(.*){configuration}-{experiment}(.*)", pod=~"(.*){configuration}-{experiment}(.*)", container="dbms"}}[5m]))',
                        'title': 'CPU Throttle'
                    },
                    'total_cpu_throttled_s': {
                        'type': 'cluster',
                        'active': True,
                        'metric': 'counter',
                        'query': 'sum(container_cpu_cfs_throttled_seconds_total{{pod=~"(.*){configuration}-{experiment}(.*)", pod=~"(.*){configuration}-{experiment}(.*)", container="dbms"}})',
                        'title': 'CPU Throttled Time [s]'
                    },
                    'total_cpu_util_others': {
                        'type': 'cluster',
                        'active': False,
                        'metric': 'gauge',
                        'query': 'sum(irate(container_cpu_usage_seconds_total{{pod=~"(.*){configuration}-{experiment}(.*)", pod=~"(.*){configuration}-{experiment}(.*)", container!="dbms",id!="/"}}[5m]))',
                        'title': 'CPU Utilization Others'
                    },
                    'total_cpu_util_s': {
                        'type': 'cluster',
                        'active': True,
                        'metric': 'counter',
                        'query': 'sum(container_cpu_usage_seconds_total{{pod=~"(.*){configuration}-{experiment}(.*)", pod=~"(.*){configuration}-{experiment}(.*)", container="dbms"}})',
                        'title': 'CPU Utilization Time [s]'
                    },
                    'total_cpu_util_user_s': {
                        'type': 'cluster',
                        'active': True,
                        'metric': 'counter',
                        'query': 'sum(container_cpu_user_seconds_total{{pod=~"(.*){configuration}-{experiment}(.*)", pod=~"(.*){configuration}-{experiment}(.*)", container="dbms"}})',
                        'title': 'CPU User Time [s]'
                    },
                    'total_cpu_util_sys_s': {
                        'type': 'cluster',
                        'active': True,
                        'metric': 'counter',
                        'query': 'sum(container_cpu_system_seconds_total{{pod=~"(.*){configuration}-{experiment}(.*)", pod=~"(.*){configuration}-{experiment}(.*)", container="dbms"}})',
                        'title': 'CPU System Time [s]'
                    },
                    'total_cpu_util_others_s': {
                        'type': 'cluster',
                        'active': False,
                        'metric': 'counter',
                        'query': 'sum(container_cpu_usage_seconds_total{{pod=~"(.*){configuration}-{experiment}(.*)", pod=~"(.*){configuration}-{experiment}(.*)", container!="dbms",id!="/"}})',
                        'title': 'CPU Utilization Time Others [s]'
                    },
                    'total_network_rx': {
                        'type': 'cluster',
                        'active': True,
                        'metric': 'counter',
                        'query': 'sum(container_network_receive_bytes_total{{pod=~"(.*){configuration}-{experiment}(.*)"}})/1024/1024',
                        'title': 'Network Rx Total [MiB]'
                    },
                    'total_network_tx': {
                        'type': 'cluster',
                        'active': True,
                        'metric': 'counter',
                        'query': 'sum(container_network_transmit_bytes_total{{pod=~"(.*){configuration}-{experiment}(.*)"}})/1024/1024',
                        'title': 'Network Tx Total [MiB]'
                    },
                    'total_fs_read': {
                        'type': 'cluster',
                        'active': True,
                        'metric': 'counter',
                        'query': 'sum(container_fs_reads_bytes_total{{pod=~"(.*){configuration}-{experiment}(.*)", container="dbms"}})/1024/1024',
                        'title': 'Filesystem Read Total [MiB]'
                    },
                    'total_fs_write': {
                        'type': 'cluster',
                        'active': True,
                        'metric': 'counter',
                        'query': 'sum(container_fs_writes_bytes_total{{pod=~"(.*){configuration}-{experiment}(.*)", container="dbms"}})/1024/1024',
                        'title': 'Filesystem Write Total [MiB]'
                    },
                    'total_gpu_util': {
                        'type': 'cluster',
                        'active': False,
                        'metric': 'gauge',
                        'query': 'sum(DCGM_FI_DEV_GPU_UTIL{{UUID=~"{gpuid}"}})',
                        'title': 'GPU Utilization [%]'
                    },
                    'total_gpu_power': {
                        'type': 'cluster',
                        'active': False,
                        'metric': 'gauge',
                        'query': 'sum(DCGM_FI_DEV_POWER_USAGE{{UUID=~"{gpuid}"}})',
                        'title': 'GPU Power Usage [W]'
                    },
                    'total_gpu_memory': {
                        'type': 'cluster',
                        'active': False,
                        'metric': 'gauge',
                        'query': 'sum(DCGM_FI_DEV_FB_USED{{UUID=~"{gpuid}"}})',
                        'title': 'GPU Memory Usage [MiB]'
                    },
                    'core_variance': {
                        'type': 'cluster',
                        'active': True,
                        'metric': 'ratio',
                        'query': '100 * (avg((sum by (exported_cpu) (rate(node_cpu_seconds_total{{mode!="idle", instance="{host}"}}[5m])))^2)-(avg(sum by (exported_cpu) (rate(node_cpu_seconds_total{{mode!="idle", instance="{host}"}}[5m]))))^2)',
                        'title': 'Core Utilization Variance [%]'
                    },
                    'max_core_util': {
                        'type': 'cluster',
                        'active': True,
                        'metric': 'ratio',
                        'query': '100 * (max(sum by (exported_cpu) (rate(node_cpu_seconds_total{{mode!="idle", instance="{host}"}}[5m]))^2))',
                        'title': 'Max Core Utilization [%]'
                    },
                    'io_wait_pct': {
                        'type': 'cluster',
                        'active': True,
                        'metric': 'ratio',
                        'query': '100 * sum by (instance) (rate(node_cpu_seconds_total{{mode="iowait", instance="{host}"}}[5m])) / sum by (instance) (rate(node_cpu_seconds_total{{mode!="idle", instance="{host}"}}[5m]))',
                        'title': 'I/O Wait [%]'
                    },
                    'io_wait_total': {
                        'type': 'cluster',
                        'active': True,
                        'metric': 'counter', # but not summed over all containers
                        'query': 'sum(node_cpu_seconds_total{{instance="{host}", mode="iowait"}})',
                        'title': 'Total I/O Wait Time [s]'
                    },
                },
                'pd': {
                    'metrics': {
                        # PD cluster leader count — should normally be 1; changes indicate elections.
                        'pd_cluster_leader_count': {
                            'type': 'application',
                            'active': True,
                            'metric': 'gauge',
                            'query': 'pd_cluster_status{{type="leader_count"}}',
                            'title': 'PD Cluster Leader Count'
                        },
                        # Number of PD scheduler leader balance operations.
                        'pd_scheduler_balance_leader_actions': {
                            'type': 'application',
                            'active': True,
                            'metric': 'counter',
                            'query': 'sum(pd_scheduler_balance_leader)',
                            'title': 'PD Leader Balance Actions [ops]'
                        },
                        # Number of PD scheduler leader balance operations per second.
                        #'pd_scheduler_balance_leader_rate': {
                        #    'type': 'application',
                        #    'active': True,
                        #    'metric': 'gauge',
                        #    'query': 'rate(pd_scheduler_balance_leader[5m])',
                        #    'title': 'PD Leader Balance Actions [ops/s]'
                        #},
                    },
                },
                'tidb': {
                    'metrics': {
                        # Total SQL statements executed per second (SELECT, UPDATE, INSERT, ...)
                        'tidb_sql_statement_rate': {
                            'type': 'application',
                            'active': True,
                            'metric': 'counter',
                            'query': 'sum(rate(tidb_executor_statement_total[5m]))',
                            'title': 'TiDB SQL Statement Throughput [ops/s]'
                        },
                        # Average TiDB query execution duration (latency)
                        'tidb_query_duration_avg': {
                            'type': 'application',
                            'active': True,
                            'metric': 'gauge',
                            'query': '1000*sum(tidb_server_handle_query_duration_seconds_sum) / sum(tidb_server_handle_query_duration_seconds_count)',
                            'title': 'TiDB Avg Query Duration [ms]'
                        },
                    },
                },
                'tikv': {
                    'metrics': {
                        # TiKV store size used in Gi, a key indicator of region/data distribution
                        'tikv_store_size_bytes': {
                            'type': 'application',
                            'active': True,
                            'metric': 'gauge',
                            'query': 'sum(tikv_store_size_bytes{{type="used"}})/1024/1024/1024',
                            'title': 'TiKV Store Size Used [Gi]'
                        },
                        # TiKV store size used in percent, a key indicator of region/data distribution
                        'tikv_store_size_bytes': {
                            'type': 'application',
                            'active': True,
                            'metric': 'gauge',
                            'query': 'sum(tikv_store_size_bytes{{type="used"}})/sum(tikv_store_size_bytes{{type="capacity"}})*100',
                            'title': 'TiKV Store Used [%]'
                        },
                        # RocksDB compaction duration — heavy indicator of TiKV disk load
                        'tikv_compaction_time': {
                            'type': 'application',
                            'active': True,
                            'metric': 'counter',
                            'query': 'sum(tikv_engine_compaction_time{{type="compaction_time_median"}})',
                            'title': 'TiKV Compaction Time Median [s]'
                        },
                        # RocksDB compaction duration — heavy indicator of TiKV disk load
                        'tikv_compaction_flow': {
                            'type': 'application',
                            'active': True,
                            'metric': 'counter',
                            'query': 'sum(tikv_engine_compaction_flow_bytes)/1024/1024/1024',
                            'title': 'TiKV Compaction Flow [Gi]'
                        },
                        # RocksDB compaction duration — heavy indicator of TiKV disk load
                        'tikv_compaction_pending': {
                            'type': 'application',
                            'active': True,
                            'metric': 'counter',
                            'query': 'sum(tikv_engine_pending_compaction_bytes)/1024/1024/1024',
                            'title': 'TiKV Compaction Pending [Gi]'
                        }
                    }
                },
                'yb_master': {
                    'metrics': {
                        # Total RPC requests handled by YB-Master (cluster metadata operations)
                        'yb_master_rpc_rate': {
                            'type': 'application',
                            'active': True,
                            'metric': 'counter',
                            'query': 'sum(rate(handler_latency_yb_master_MasterService_Request_total_count[5m]))',
                            'title': 'YB-Master RPC Throughput [ops/s]'
                        },

                        # Average latency of master RPC requests
                        'yb_master_rpc_latency_avg': {
                            'type': 'application',
                            'active': True,
                            'metric': 'gauge',
                            'query': '1000 * sum(handler_latency_yb_master_MasterService_Request_sum) / sum(handler_latency_yb_master_MasterService_Request_count)',
                            'title': 'YB-Master Avg RPC Latency [ms]'
                        },

                        # Number of tablets registered in the cluster
                        'yb_master_tablet_count': {
                            'type': 'application',
                            'active': True,
                            'metric': 'gauge',
                            'query': 'sum(yb_master_tablet_count)',
                            'title': 'Total Tablets in Cluster'
                        },

                        # Leader election / replication lag indicator
                        'yb_master_follower_lag': {
                            'type': 'application',
                            'active': True,
                            'metric': 'gauge',
                            'query': 'max(follower_lag_ms)',
                            'title': 'YB-Master Follower Lag [ms]'
                        },

                        # Number of live tablet servers known by the master
                        'yb_master_live_tservers': {
                            'type': 'application',
                            'active': True,
                            'metric': 'gauge',
                            'query': 'sum(yb_master_num_live_tservers)',
                            'title': 'Live TServers'
                        },
                    },
                },
                'yb_tserver': {
                    'metrics': {
                        # Total YSQL queries executed per second
                        'yb_tserver_ysql_query_rate': {
                            'type': 'application',
                            'active': True,
                            'metric': 'counter',
                            'query': 'sum(rate(handler_latency_yb_tserver_TabletServerService_Read_count[5m]) + rate(handler_latency_yb_tserver_TabletServerService_Write_count[5m]))',
                            'title': 'YSQL Query Throughput [ops/s]'
                        },

                        # Average read latency on tablets
                        'yb_tserver_read_latency_avg': {
                            'type': 'application',
                            'active': True,
                            'metric': 'gauge',
                            'query': '1000 * sum(handler_latency_yb_tserver_TabletServerService_Read_sum) / sum(handler_latency_yb_tserver_TabletServerService_Read_count)',
                            'title': 'Tablet Read Latency [ms]'
                        },

                        # Average write latency on tablets
                        'yb_tserver_write_latency_avg': {
                            'type': 'application',
                            'active': True,
                            'metric': 'gauge',
                            'query': '1000 * sum(handler_latency_yb_tserver_TabletServerService_Write_sum) / sum(handler_latency_yb_tserver_TabletServerService_Write_count)',
                            'title': 'Tablet Write Latency [ms]'
                        },

                        # Active YSQL connections
                        'yb_tserver_ysql_connections': {
                            'type': 'application',
                            'active': True,
                            'metric': 'gauge',
                            'query': 'sum(yb_ysqlserver_active_connections)',
                            'title': 'Active YSQL Connections'
                        },

                        # Replication lag across tablets
                        'yb_tserver_follower_lag': {
                            'type': 'application',
                            'active': True,
                            'metric': 'gauge',
                            'query': 'max(follower_lag_ms)',
                            'title': 'TServer Follower Lag [ms]'
                        },
                    },
                },
                'redis': {
                    'metrics': {
                        # Redis cluster state — 1 means healthy, 0 means fail.
                        'redis_cluster_state': {
                            'type': 'application',
                            'active': True,
                            'metric': 'gauge',
                            'query': 'sum(redis_cluster_state)', # or min(redis_cluster_state)
                            'title': 'Redis Cluster State'
                        },
                        # Connected clients — sudden spikes may indicate traffic surge or connection leaks.
                        'redis_connected_clients': {
                            'type': 'application',
                            'active': True,
                            'metric': 'gauge',
                            'query': 'sum(redis_connected_clients)',
                            'title': 'Connected Clients [count]'
                        },
                        # Memory usage — critical for avoiding eviction or OOM.
                        'redis_memory_used_bytes': {
                            'type': 'application',
                            'active': True,
                            'metric': 'gauge',
                            'query': 'sum(redis_memory_used_bytes)/1024/1024/1024',
                            'title': 'Redis Memory Used [Gi]'
                        },
                        # Replication health — 0 means replication link down.
                        'redis_master_link_up': {
                            'type': 'application',
                            'active': True,
                            'metric': 'gauge',
                            'query': 'sum(redis_master_link_up)', # or sum(redis_master_link_up == 0)
                            'title': 'Redis Master Link Status'
                        },
                        # Commands processed per second — core throughput indicator.
                        'redis_ops_rate': {
                            'type': 'application',
                            'active': True,
                            'metric': 'counter',
                            'query': 'max(rate(redis_commands_processed_total[5m]))',
                            'title': 'Redis Operations Rate [ops/s]'
                        },
                        'redis_keyspace_hit_ratio': {
                            'type': 'application',
                            'active': True,
                            'metric': 'gauge',
                            'query': 'sum(increase(redis_keyspace_hits_total[5m]))/(sum(increase(redis_keyspace_hits_total[5m])) + sum(increase(redis_keyspace_misses_total[5m])))',
                            'title': 'Keyspace Hit Ratio [0..1]'
                        },
                        'redis_replica_lag_seconds': {
                            'type': 'application',
                            'active': True,
                            'metric': 'gauge',
                            'query': 'max(redis_connected_slave_lag_seconds)',
                            'title': 'Replication Lag (max across replicas) [s]'
                        },
                        'redis_replica_count': {
                            'type': 'application',
                            'active': True,
                            'metric': 'gauge',
                            'query': 'sum(redis_connected_slaves)',
                            'title': 'Number of replicas [count]'
                        },
                    },
                },
                'cockroachdb': {
                    'metrics': {
                        # Rate of Raft MsgAppResp messages received per second, a core indicator of Raft protocol traffic and health
                        'raft_messages_received_appresp_rate': {
                            'type': 'application',
                            'active': True,
                            'metric': 'counter',
                            'query': 'sum(rate(raft_rcvd_appresp[5m]))',
                            'title': 'Raft Messages Received (AppResp) [msgs/s]'
                        },
                        # Rate of all Raft message bytes received per second, indicating network load from the Raft protocol
                        'raft_network_in_bytes_rate': {
                            'type': 'application',
                            'active': True,
                            'metric': 'counter',
                            'query': 'sum(rate(raft_rcvd_bytes[5m]))',
                            'title': 'Raft Network In (Bytes/sec)'
                        },
                        # Rate of bytes received from Raft recovery snapshots per second, indicating ongoing range repair or re-replication activity
                        'raft_recovery_snapshot_in_bytes_rate': {
                            'type': 'application',
                            'active': True,
                            'metric': 'counter',
                            'query': 'sum(rate(range_snapshots_recovery_rcvd_bytes[5m]))',
                            'title': 'Raft Recovery Snapshot In (Bytes/sec)'
                        },
                        # Rate of replica additions attempted by the replicate queue per second, indicating balancing attempts
                        'replicate_queue_add_replica_rate': {
                            'type': 'application',
                            'active': True,
                            'metric': 'counter',
                            'query': 'sum(rate(queue_replicate_addreplica[5m]))',
                            'title': 'Replicate Queue Adds Attempted [adds/s]'
                        },
                        # Total count of replicas currently stalled in the replicate queue's purgatory, waiting for allocation options
                        'replicate_queue_purgatory_count': {
                            'type': 'application',
                            'active': True,
                            'metric': 'gauge',
                            'query': 'sum(queue_replicate_purgatory)',
                            'title': 'Replicate Queue Purgatory Count'
                        },
                        # Rate of times the allocator found a valid lease transfer candidate that was not on an overfull store
                        'lease_transfer_existing_not_overfull_rate': {
                            'type': 'application',
                            'active': True,
                            'metric': 'counter',
                            'query': 'sum(rate(kv_allocator_load_based_lease_transfers_existing_not_overfull[5m]))',
                            'title': 'Lease Transfer Not Overfull Rate [events/s]'
                        },
                        # Rate of occurrences where an overfull store failed to shed load after exhausting rebalance options
                        'rebalancing_overfull_options_exhausted_rate': {
                            'type': 'application',
                            'active': True,
                            'metric': 'counter',
                            'query': 'sum(rate(rebalancing_state_imbalanced_overfull_options_exhausted[5m]))',
                            'title': 'Rebalancing Overfull Options Exhausted Rate [events/s]'
                        },
                        # Total number of healthy, bidirectionally connected RPC connections across the cluster
                        'rpc_healthy_connections_count': {
                            'type': 'application',
                            'active': True,
                            'metric': 'gauge',
                            'query': 'sum(rpc_connection_healthy)',
                            'title': 'Healthy RPC Connections'
                        },
                        # Rate of TransactionRetryWithProtoRefreshErrType errors, indicating high transaction contention or restarts
                        'distsender_rpc_err_transactionretrywithprotorefresherrtype_rate': {
                            'type': 'application',
                            'active': True,
                            'metric': 'counter',
                            'query': 'sum(rate(distsender_rpc_err_transactionretrywithprotorefresherrtype[5m]))',
                            'title': 'DistSender Transaction Retry Error Rate [errors/s]'
                        },
                        # Total number of bytes taken up by all values stored across the entire cluster, a key capacity metric
                        'total_data_size_bytes': {
                            'type': 'application',
                            'active': True,
                            'metric': 'gauge',
                            'query': 'sum(valbytes)',
                            'title': 'Total Stored Data Size (Bytes)'
                        },
                    },
                },
                'mysql': {
                    'metrics': {
                        'mysql_buffer_pool_hit_ratio': {
                            'type': 'application',
                            'active': True,
                            'metric': 'gauge',
                            'query': '(rate(mysql_global_status_innodb_buffer_pool_reads[5m]) == 0) or (1 - (rate(mysql_global_status_innodb_buffer_pool_reads[5m]) / rate(mysql_global_status_innodb_buffer_pool_read_requests[5m])))',
                            'title': 'InnoDB Buffer Pool Hit Ratio'
                        },
                        'mysql_queries_per_second': {
                            'type': 'application',
                            'active': True,
                            'metric': 'gauge',
                            'query': 'rate(mysql_global_status_queries[5m])',
                            'title': 'Queries Per Second (QPS)'
                        },
                        'mysql_connections_usage': {
                            'type': 'application',
                            'active': True,
                            'metric': 'gauge',
                            'query': 'mysql_global_status_threads_connected / mysql_global_variables_max_connections',
                            'title': 'Connection Usage Ratio'
                        },
                        'mysql_slow_queries': {
                            'type': 'application',
                            'active': True,
                            'metric': 'counter',
                            'query': 'rate(mysql_global_status_slow_queries[5m])',
                            'title': 'Slow Queries Rate'
                        },
                        'mysql_innodb_log_waits': {
                            'type': 'application',
                            'active': True,
                            'metric': 'counter',
                            'query': 'rate(mysql_global_status_innodb_log_waits[5m])',
                            'title': 'InnoDB Log Waits Rate'
                        },
                        'innodb_log_fsyncs_per_second': {
                            'type': 'application',
                            'active': True,
                            'metric': 'gauge',
                            'query': 'sum(rate(mysql_global_status_innodb_os_log_fsyncs[5m]))',
                            'title': 'InnoDB Redo Log fsyncs per second'
                        },
                        'innodb_avg_bytes_per_fsync': {
                            'type': 'application',
                            'active': True,
                            'metric': 'gauge',
                            'query': 'sum(rate(mysql_global_status_innodb_os_log_written[1m])) / sum(rate(mysql_global_status_innodb_os_log_fsyncs[1m]))',
                            'title': 'Average Redo Log Bytes per fsync'
                        },
                        'innodb_buffer_pool_wait_free': {
                            'type': 'application',
                            'active': True,
                            'metric': 'gauge',
                            'query': 'sum(avg_over_time(mysql_global_status_innodb_buffer_pool_wait_free[5m]))',
                            'title': 'InnoDB Buffer Pool Wait Free'
                        },
                        'innodb_max_dirty_pages_pct': {
                            'type': 'application',
                            'active': True,
                            'metric': 'gauge',
                            'query': 'sum(mysql_global_variables_innodb_max_dirty_pages_pct)',
                            'title': 'InnoDB Max Dirty Pages %'
                        },
                        'innodb_max_dirty_pages_pct_lwm': {
                            'type': 'application',
                            'active': True,
                            'metric': 'gauge',
                            'query': 'sum(mysql_global_variables_innodb_max_dirty_pages_pct_lwm)',
                            'title': 'InnoDB Max Dirty Pages % Low Watermark'
                        },
                        'innodb_buffer_pool_bytes_dirty': {
                            'type': 'application',
                            'active': True,
                            'metric': 'gauge',
                            'query': 'sum(avg_over_time(mysql_global_status_innodb_buffer_pool_bytes_dirty[5m]))',
                            'title': 'InnoDB Buffer Pool Dirty Bytes'
                        },
                        'innodb_buffer_pool_dirty_pages': {
                            'type': 'application',
                            'active': True,
                            'metric': 'gauge',
                            'query': 'sum(avg_over_time(mysql_global_status_buffer_pool_dirty_pages[5m]))',
                            'title': 'InnoDB Buffer Pool Dirty Pages'
                        },
                        'innodb_buffer_pool_pages_flushed': {
                            'type': 'application',
                            'active': True,
                            'metric': 'gauge',
                            'query': 'sum(rate(mysql_global_status_buffer_pool_page_changes_total{{operation="flushed"}}[5m]))',
                            'title': 'InnoDB Buffer Pool Pages Flushed per Second'
                        },
                        'innodb_buffer_pool_bytes_data': {
                            'type': 'application',
                            'active': True,
                            'metric': 'gauge',
