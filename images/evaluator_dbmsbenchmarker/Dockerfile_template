######################################################################################
# Dockerfile template for Bexhoma - Evaluator DBMSBenchmarker
######################################################################################
#
# This Dockerfile template builds an image for a Bexhoma evaluator that runs
# the DBMSBenchmarker dashboard and a Jupyter Notebook server.
#
# Base Image: python:3.12.8
#   (python:3.14.2 is not compatible with flask: 'pkgutil' has no attribute 'get_loader')
#
# NOTE: This is a template processed by create_Dockerfiles.py.
#       The placeholder {version} is replaced with the DBMSBenchmarker version tag.
#       Use: python create_Dockerfiles.py -v <version> -i <image-tag>
#
# Author: Patrick K. Erdelt
# Email: patrick.erdelt@bht-berlin.de
# Date: 2025-05-18
# Version: 1.0
# Description: Serves the DBMSBenchmarker dashboard (port 8050) and a Jupyter
#   Notebook server (port 8888, password = admin) for experiment evaluation.
#   Java, git, and a Python virtualenv are set up inside the image.
######################################################################################
FROM python:3.12.8

######################################################################################
# Install system dependencies (Java runtime, git)
######################################################################################
RUN apt-get update && apt-get install -y git default-jre nano && rm -rf /var/lib/apt/lists/*

######################################################################################
# Install DBMSBenchmarker Python package ({version}) — system-wide first pass
######################################################################################
RUN pip uninstall dbmsbenchmarker -y
RUN JAVA_HOME=/usr/lib/jvm/java-1.8.0/ pip install --no-cache-dir --upgrade --force-reinstall git+https://github.com/Beuth-Erdelt/DBMS-Benchmarker@{version}

######################################################################################
# Clone DBMSBenchmarker repository into /usr/src/app/DBMS-Benchmarker
######################################################################################
RUN git clone --branch {version} https://github.com/Beuth-Erdelt/DBMS-Benchmarker /usr/src/app/DBMS-Benchmarker

WORKDIR /usr/src/app/DBMS-Benchmarker

######################################################################################
# Create and activate a Python virtualenv, then reinstall DBMSBenchmarker inside it
######################################################################################
SHELL ["/bin/bash", "-c"]

ENV VIRTUAL_ENV=/opt/venv

RUN python -m pip install virtualenv
RUN python -m venv $VIRTUAL_ENV
ENV PATH="$VIRTUAL_ENV/bin:$PATH"

RUN pip install --no-cache-dir --upgrade --force-reinstall git+https://github.com/Beuth-Erdelt/DBMS-Benchmarker@{version}

######################################################################################
# Install Jupyter Notebook
######################################################################################
RUN pip install jupyter
RUN pip install jupyter_contrib_nbextensions

######################################################################################
# Clone a second copy of the repository inside the working directory
# (provides access to raw source files alongside the installed package)
######################################################################################
RUN git clone https://github.com/Beuth-Erdelt/DBMS-Benchmarker --branch {version}

WORKDIR /usr/src/app/DBMS-Benchmarker

######################################################################################
# Copy evaluation notebooks
######################################################################################
RUN mkdir /usr/src/app/DBMS-Benchmarker/notebooks

COPY ./notebooks /usr/src/app/DBMS-Benchmarker/notebooks

######################################################################################
# Start the DBMSBenchmarker dashboard
######################################################################################
CMD ls /usr/src/app/DBMS-Benchmarker -lh; ls /usr/src/app/DBMS-Benchmarker/DBMS-Benchmarker -lh; python ./dashboard.py -r /results
